<h1>Tasks Index Page</h1>

<table>
  <thead>
    <tr>
      <th>Title</th>
      <th>Content</th>
      <th>Created_at</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @tasks.each do |task| %>
      <tr>
        <td><%= task.title %></td>
        <td><%= task.content %></td>
        <td><%= task.created_at %></td>
        <td><%= link_to 'Show', task, class: 'show-task' %></td>
        <td><%= link_to 'Edit', edit_task_path(task), class: 'edit-task' %></td>
        <td>
          <%= button_to 'Destroy', task_path(task), method: :delete, 
              onclick: "return confirm('Are you sure?')", 
              class: 'destroy-task' %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<%= link_to 'New Task', new_task_path, id: 'new-task' %>
