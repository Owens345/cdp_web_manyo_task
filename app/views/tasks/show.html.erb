<h1><%= t('views.tasks.show.title') %></h1>
<p><strong><%= Task.human_attribute_name(:title) %></strong> <%= @task.title %></p>
<p><strong><%= Task.human_attribute_name(:content) %></strong> <%= @task.content %></p>
<p><strong><%= Task.human_attribute_name(:created_at) %></strong> <%= @task.created_at %></p>
<%= link_to t('views.tasks.show.edit'), edit_task_path(@task), id: 'edit-task' %>
<%= link_to t('views.tasks.show.back'), tasks_path, id: 'back' %>
