<h1>ログインページ</h1>
<% if flash[:alert] %>
  <p><%= flash[:alert] %></p>
<% end %>
<%= form_with url: login_path, scope: :session, local: true do |f| %>
  <div>
    <%= f.label :email, 'メールアドレス' %>
    <%= f.email_field :email %>
  </div>
  <div>
    <%= f.label :password, 'パスワード' %>
    <%= f.password_field :password %>
  </div>
  <%= f.submit 'ログイン', id: 'create-session' %>
<% end %>
